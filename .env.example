# Pocket Mint Backend — environment template.
# Copy to `.env` and fill with real values. NEVER commit real secrets.

# --- Database (Supabase Postgres) ---
# Direct connection (used at runtime).
DATABASE_URL="postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres"

# Optional: pooled connections. DIRECT_URL is used by Prisma for migrations.
# DATABASE_URL="postgresql://postgres.<project-ref>:<DB_PASSWORD>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<project-ref>:<DB_PASSWORD>@<region>.pooler.supabase.com:5432/postgres"

# --- Server ---
PORT=5001
# Set to `production` in deployment so stack traces are never returned to clients.
NODE_ENV=development

# --- Auth ---
# DEPRECATED legacy shared gateway secret. Used only by the compatibility auth
# path (API key + self-asserted x-user-id) while the frontend migrates to JWTs.
# Use a high-entropy random string (e.g. `openssl rand -hex 32`).
API_KEY="<high-entropy-random-secret>"

# Supabase identity verification. Configure EITHER of the following so the
# backend can verify per-user JWTs (Authorization: Bearer <token>):
#   - Legacy HS256 shared secret (Dashboard > Project Settings > API > JWT Secret):
SUPABASE_JWT_SECRET="<supabase-jwt-secret>"
#   - OR modern asymmetric signing keys via JWKS (set the project URL):
# SUPABASE_URL="https://<project-ref>.supabase.co"

# Optional JWT claim validation overrides.
#   - Audience is always verified; defaults to "authenticated" (Supabase default).
# SUPABASE_JWT_AUD="authenticated"
#   - Issuer is verified only when set. Derived automatically as
#     "<SUPABASE_URL>/auth/v1" when SUPABASE_URL is configured.
# SUPABASE_JWT_ISSUER="https://<project-ref>.supabase.co/auth/v1"

# When 'true', a verified Supabase JWT is REQUIRED and the legacy self-asserted
# x-user-id header fallback is disabled. Leave unset/false during frontend
# migration; flip to true once the frontend always sends Bearer tokens.
AUTH_REQUIRE_JWT=false

# --- Rate limiting ---
# In-memory limiter (per-instance). Use a shared store (Redis) if scaling out.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000        # window length in ms (default 15 minutes)
RATE_LIMIT_MAX=300                 # max requests per window (general API traffic)
RATE_LIMIT_MUTATION_MAX=60         # stricter cap per window for POST/PUT/PATCH/DELETE

# --- Reverse proxy ---
# Number of trusted reverse-proxy hops in front of the app (governs req.ip used
# for rate-limit keying). 0/unset = trust none. Set to 1 behind a single load
# balancer. Avoid `true` (allows X-Forwarded-For spoofing of the limit key).
TRUST_PROXY=0

# --- CORS ---
# Comma-separated list of EXACT allowed browser origins. No wildcard.
# REQUIRED in production (startup fails if empty). In development this may be
# left unset, which falls back to http://localhost:3000 and :5173.
CORS_ALLOWED_ORIGINS="https://app.example.com,https://www.example.com"

# =====================================================================
# Frontend auth migration guide (closing security-audit S1/S2)
# ---------------------------------------------------------------------
# 1. Rotate leaked credentials: reset the Supabase database password and
#    generate a new API_KEY. (Untracking the old .env files did NOT undo
#    the historical exposure — the old values must be treated as burned.)
# 2. Configure JWT verification here: set SUPABASE_JWT_SECRET, or set
#    SUPABASE_URL to use asymmetric JWKS signing keys.
# 3. Update the frontend to send the Supabase access token on every API
#    call: `Authorization: Bearer <access_token>`.
# 4. Watch the logs for the throttled "deprecated legacy auth path used"
#    warning to confirm no client still relies on x-user-id.
# 5. Once the warning stops, set AUTH_REQUIRE_JWT=true to disable the
#    legacy API-key + x-user-id fallback.
# 6. In a later dedicated commit, remove the x-user-id / API-key identity
#    fallback code entirely.
# =====================================================================
# Application-wide IANA timezone used for transaction reporting calendar days.
# Per-user reporting timezones are not currently supported.
REPORTING_TIMEZONE=Asia/Jakarta
