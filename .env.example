# Pocket Mint Backend — environment template.
# Copy to `.env` and fill with real values. NEVER commit real secrets.

# --- Database (Supabase Postgres) ---
# Direct connection (used at runtime).
DATABASE_URL="postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres"

# Optional: pooled connections. DIRECT_URL is used by Prisma for migrations.
# DATABASE_URL="postgresql://postgres.<project-ref>:<DB_PASSWORD>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<project-ref>:<DB_PASSWORD>@<region>.pooler.supabase.com:5432/postgres"
#
# The runtime connects through the pg driver adapter (Prisma 7 `client` engine).
# Connection pool sizing is PER PROCESS — total server-side connections equal
# (DB_POOL_MAX × running instances); keep that product under the provider limit.
# All optional; conservative defaults are used if unset.
# DB_POOL_MAX=10                 # max connections held by this process's pool
# DB_IDLE_TIMEOUT_MS=10000       # close idle pooled connections after N ms
# DB_CONNECTION_TIMEOUT_MS=10000 # fail connection acquisition after N ms
#
# Disposable-DB integration test only (never Supabase). When set, the
# adapter-backed integration suite runs against this throwaway database whose
# schema already matches prisma/schema.prisma:
# TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pocketmint_test"

# --- Server ---
PORT=5001
# Set to `production` in deployment so stack traces are never returned to clients.
NODE_ENV=development

# --- Auth (JWT-only) ---
# Authentication is verified Supabase JWT ONLY. Every user-scoped request must
# send `Authorization: Bearer <supabase-access-token>`. There is no shared API
# key and no `x-user-id` identity — the shared-key + x-user-id path was retired.
#
# Configure EXACTLY ONE JWT verification key source (REQUIRED — startup fails in
# production if neither is set, and all authentication returns 401 without one):
#   - HS256 shared secret (Dashboard > Project Settings > API > JWT Secret):
SUPABASE_JWT_SECRET="<supabase-jwt-secret>"
#   - OR modern asymmetric signing keys via JWKS (set the project URL instead):
# SUPABASE_URL="https://<project-ref>.supabase.co"

# Optional JWT claim validation overrides.
#   - Audience is always verified; defaults to "authenticated" (Supabase default).
# SUPABASE_JWT_AUD="authenticated"
#   - Issuer is verified only when set. Derived automatically as
#     "<SUPABASE_URL>/auth/v1" when SUPABASE_URL is configured.
# SUPABASE_JWT_ISSUER="https://<project-ref>.supabase.co/auth/v1"

# --- Rate limiting ---
# In-memory limiter (per-instance). Use a shared store (Redis) if scaling out.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000        # window length in ms (default 15 minutes)
RATE_LIMIT_MAX=300                 # max requests per window (general API traffic)
RATE_LIMIT_MUTATION_MAX=60         # stricter cap per window for POST/PUT/PATCH/DELETE

# --- Reverse proxy ---
# Number of trusted reverse-proxy hops in front of the app (governs req.ip used
# for rate-limit keying). 0/unset = trust none. Set to 1 behind a single load
# balancer. Avoid `true` (allows X-Forwarded-For spoofing of the limit key).
TRUST_PROXY=0

# --- CORS ---
# Comma-separated list of EXACT allowed browser origins. No wildcard.
# REQUIRED in production (startup fails if empty). In development this may be
# left unset, which falls back to http://localhost:3000 and :5173.
CORS_ALLOWED_ORIGINS="https://app.example.com,https://www.example.com"

# =====================================================================
# Auth model: JWT-only (legacy identity path retired — Sprint 3I)
# ---------------------------------------------------------------------
# The shared API key + self-asserted x-user-id path has been REMOVED. The
# backend authenticates exclusively via verified Supabase JWTs.
#   - Frontend: send `Authorization: Bearer <supabase-access-token>` on EVERY
#     protected request (see docs/frontend-jwt-migration.md).
#   - POST /users/sync is authenticated the same way (verified JWT); it
#     bootstraps the local user from the verified `sub` — no API key.
#   - Rotate the historically exposed Supabase DB password and the old shared
#     API key: they are burned regardless of this change (git history still
#     contains them until purged in coordination).
# =====================================================================
# Application-wide IANA timezone used for transaction reporting calendar days.
# Per-user reporting timezones are not currently supported.
REPORTING_TIMEZONE=Asia/Jakarta
