// ============================================================
// Pocket Mint — Personal Finance Tracker
// Prisma Schema for PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
  // Output must match the path imported by src/lib/prisma.ts
  // ('../generated/prisma/client', which resolves to this directory's shim).
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  // NOTE: no password column. Authentication is owned entirely by Supabase Auth;
  // this backend never stores, hashes, or verifies passwords. Local users are
  // linked to the verified Supabase identity via `id` (the JWT `sub` claim).
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  wallets                       Wallet[]
  categories                    Category[]
  transactions                  Transaction[]
  installments                  Installment[]
  recurringTransactionTemplates RecurringTransactionTemplate[]
  savingGoals                   SavingGoal[]
  budgets                       Budget[]
  merchantMappings              MerchantMapping[]
  assistantConversations        AssistantConversation[]
  assistantFinancialDrafts      AssistantFinancialDraft[]
  assistantIdempotencyRecords   AssistantIdempotencyRecord[]

  @@map("users")
}

enum AssistantConversationStatus {
  ACTIVE
  ARCHIVED
  EXPIRED
}

enum AssistantTurnStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  REJECTED
  CLARIFICATION_REQUIRED
}

enum AssistantMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AssistantMessageSource {
  USER_PROVIDED
  CANONICAL_FALLBACK
  SAFE_REQUEST_SUMMARY
  DETERMINISTIC_RENDERER
  SAFE_ERROR
}

enum AssistantToolExecutionStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
  DENIED
}

enum AssistantFinancialDraftStatus {
  PENDING_CONFIRMATION
  COMMITTED
  CANCELLED
  EXPIRED
  FAILED
}

model AssistantConversation {
  id             String                      @id @default(cuid())
  userId         String                      @map("user_id")
  status         AssistantConversationStatus @default(ACTIVE)
  locale         String                      @default("id-ID")
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")
  lastActivityAt DateTime                    @default(now()) @map("last_activity_at")
  archivedAt     DateTime?                   @map("archived_at")

  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  turns           AssistantTurn[]
  messages        AssistantMessage[]
  toolExecutions  AssistantToolExecution[]
  financialDrafts AssistantFinancialDraft[]

  @@index([userId, lastActivityAt, id])
  @@index([userId, status, lastActivityAt])
  @@map("assistant_conversations")
}

model AssistantTurn {
  id             String              @id @default(cuid())
  conversationId String              @map("conversation_id")
  correlationId  String              @unique @map("correlation_id")
  status         AssistantTurnStatus @default(PENDING)
  intent         String
  locale         String
  safeErrorCode  String?             @map("safe_error_code")
  startedAt      DateTime            @default(now()) @map("started_at")
  finishedAt     DateTime?           @map("finished_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  conversation    AssistantConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages        AssistantMessage[]
  toolExecutions  AssistantToolExecution[]
  financialDrafts AssistantFinancialDraft[]

  @@index([conversationId, createdAt, id])
  @@index([status, startedAt])
  @@map("assistant_turns")
}

model AssistantMessage {
  id             String                 @id @default(cuid())
  conversationId String                 @map("conversation_id")
  turnId         String                 @map("turn_id")
  role           AssistantMessageRole
  source         AssistantMessageSource
  content        String
  createdAt      DateTime               @default(now()) @map("created_at")

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  turn         AssistantTurn         @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt, id])
  @@index([turnId])
  @@map("assistant_messages")
}

model AssistantFinancialDraft {
  id                     String                        @id @default(cuid())
  userId                 String                        @map("user_id")
  conversationId         String                        @map("conversation_id")
  originatingTurnId      String                        @map("originating_turn_id")
  originatingExecutionId String                        @unique @map("originating_execution_id")
  status                 AssistantFinancialDraftStatus @default(PENDING_CONFIRMATION)
  operation              String
  transactionType        TransactionType               @map("transaction_type")
  amount                 Decimal                       @db.Decimal(15, 2)
  walletId               String                        @map("wallet_id")
  categoryId             String                        @map("category_id")
  transactionDate        DateTime                      @map("transaction_date")
  description            String?
  expiresAt              DateTime                      @map("expires_at")
  committedAt            DateTime?                     @map("committed_at")
  cancelledAt            DateTime?                     @map("cancelled_at")
  failedAt               DateTime?                     @map("failed_at")
  transactionId          String?                       @unique @map("transaction_id")
  createdAt              DateTime                      @default(now()) @map("created_at")
  updatedAt              DateTime                      @updatedAt @map("updated_at")

  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation         AssistantConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  originatingTurn      AssistantTurn                @relation(fields: [originatingTurnId], references: [id], onDelete: Cascade)
  originatingExecution AssistantToolExecution       @relation(fields: [originatingExecutionId], references: [id], onDelete: Cascade)
  transaction          Transaction?                 @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  idempotencyRecords   AssistantIdempotencyRecord[]

  @@index([userId, status, expiresAt])
  @@index([conversationId, createdAt])
  @@map("assistant_financial_drafts")
}

model AssistantIdempotencyRecord {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  draftId       String   @map("draft_id")
  operation     String
  key           String
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft       AssistantFinancialDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  transaction Transaction?            @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([userId, key])
  @@index([draftId])
  @@map("assistant_idempotency_records")
}

model AssistantToolExecution {
  id             String                       @id @default(cuid())
  conversationId String                       @map("conversation_id")
  turnId         String                       @map("turn_id")
  toolId         String                       @map("tool_id")
  capability     String
  riskLevel      String                       @map("risk_level")
  policyDecision String                       @map("policy_decision")
  status         AssistantToolExecutionStatus @default(PENDING)
  correlationId  String                       @map("correlation_id")
  startedAt      DateTime                     @default(now()) @map("started_at")
  completedAt    DateTime?                    @map("completed_at")
  durationMs     Int?                         @map("duration_ms")
  safeErrorCode  String?                      @map("safe_error_code")
  redactedInput  Json?                        @map("redacted_input")
  outputSummary  Json?                        @map("output_summary")
  idempotencyKey String?                      @map("idempotency_key")

  conversation   AssistantConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  turn           AssistantTurn            @relation(fields: [turnId], references: [id], onDelete: Cascade)
  financialDraft AssistantFinancialDraft?

  @@index([turnId, startedAt])
  @@index([conversationId, startedAt])
  @@index([correlationId])
  @@map("assistant_tool_executions")
}

// ─────────────────────────────────────────────
// WALLET  (rekening / e-wallet / paylater)
// ─────────────────────────────────────────────
enum WalletType {
  CASH
  BANK
  E_WALLET
  CREDIT_CARD
  PAYLATER
  LOAN
}

model Wallet {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  name           String
  type           WalletType   @default(CASH)
  balance        Decimal      @default(0) @db.Decimal(15, 2)
  creditLimit    Decimal      @default(0) @map("credit_limit") @db.Decimal(15, 2)
  initialBalance Decimal      @default(0) @map("initial_balance") @db.Decimal(15, 2)
  icon           String?
  color          String?
  interestRate   Decimal      @default(0) @map("interest_rate") @db.Decimal(5, 2)
  // Bunga flat per bulan dalam persen (contoh: 2.95 = 2.95%)
  // Default 0 untuk wallet tipe ASSET
  isArchived     Boolean      @default(false) @map("is_archived")
  adminFee       Decimal      @default(0) @map("admin_fee") @db.Decimal(15, 2)
  // Biaya admin default untuk wallet ini
  // FLAT    → nilai dalam Rupiah (contoh: 45000)
  // PERCENT → nilai dalam persen (contoh: 1.5 = 1.5%)
  adminFeeType   AdminFeeType @default(FLAT) @map("admin_fee_type")
  // Tipe kalkulasi biaya admin
  cutoffDay      Int?         @map("cutoff_day")
  paymentDueDay  Int?         @map("payment_due_day")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  user                          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions                  Transaction[]                  @relation("WalletTransactions")
  // Transfers whose destination is this wallet (Transaction.toWalletId).
  toTransactions                Transaction[]                  @relation("WalletToTransactions")
  installments                  Installment[]
  recurringTransactionTemplates RecurringTransactionTemplate[]

  @@index([userId])
  @@map("wallets")
}

// ─────────────────────────────────────────────
// CATEGORY  (kategori transaksi)
// ─────────────────────────────────────────────
enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  name      String
  type      CategoryType
  icon      String?
  color     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Relations
  user                          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions                  Transaction[]
  recurringTransactionTemplates RecurringTransactionTemplate[]
  budgets                       Budget[]
  merchantMappings              MerchantMapping[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("categories")
}

// ─────────────────────────────────────────────
// MERCHANT MAPPING  (Phase 19 — per-user merchant → category alias)
// ─────────────────────────────────────────────
model MerchantMapping {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  merchantName       String   @map("merchant_name")
  normalizedMerchant String   @map("normalized_merchant")
  categoryId         String   @map("category_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedMerchant])
  @@index([userId])
  @@map("merchant_mappings")
}

// ─────────────────────────────────────────────
// TRANSACTION  (income / expense / transfer)
// ─────────────────────────────────────────────
enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  walletId      String          @map("wallet_id")
  // Destination wallet for TRANSFER rows. Persisting it makes a transfer
  // self-describing so update/delete can reverse BOTH sides from the stored
  // row (not from request data). Null for INCOME/EXPENSE and legacy transfers.
  toWalletId    String?         @map("to_wallet_id")
  categoryId    String?         @map("category_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  description   String?
  isInstallment Boolean         @default(false) @map("is_installment")
  installmentId String?         @map("installment_id")
  date          DateTime
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet                      Wallet                       @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)
  toWallet                    Wallet?                      @relation("WalletToTransactions", fields: [toWalletId], references: [id], onDelete: SetNull)
  category                    Category?                    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installment                 Installment?                 @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  reminderEvent               RecurringReminderEvent?
  assistantFinancialDraft     AssistantFinancialDraft?
  assistantIdempotencyRecords AssistantIdempotencyRecord[]

  @@index([userId, date])
  @@index([userId, type])
  @@index([walletId, date])
  @@index([toWalletId])
  @@index([categoryId])
  @@index([installmentId])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// INSTALLMENT  (cicilan)
// ─────────────────────────────────────────────
// ─────────────────────────────────────────────
// ADMIN FEE TYPE
// ─────────────────────────────────────────────
enum AdminFeeType {
  FLAT // nominal tetap dalam Rupiah
  PERCENT // persentase dari pokok transaksi
}

enum InstallmentStatus {
  ACTIVE
  SETTLED
  CANCELLED
}

enum BillKind {
  FULL
  INSTALLMENT
}

model Installment {
  id                String            @id @default(cuid())
  userId            String            @map("user_id")
  walletId          String            @map("wallet_id")
  totalAmount       Decimal           @map("total_amount") @db.Decimal(15, 2)
  interestRate      Decimal           @default(0) @map("interest_rate") @db.Decimal(5, 2)
  // Snapshot bunga saat transaksi cicilan dibuat
  totalInterest     Decimal           @default(0) @map("total_interest") @db.Decimal(15, 2)
  // Total bunga = amount × (interest_rate/100) × installmentMonths
  adminFee          Decimal           @default(0) @map("admin_fee") @db.Decimal(15, 2)
  // Snapshot nilai admin_fee saat transaksi dibuat
  adminFeeType      AdminFeeType      @default(FLAT) @map("admin_fee_type")
  // Snapshot tipe admin fee saat transaksi dibuat
  totalAdminFee     Decimal           @default(0) @map("total_admin_fee") @db.Decimal(15, 2)
  // Hasil kalkulasi aktual:
  // FLAT    → sama dengan admin_fee
  // PERCENT → amount × (admin_fee / 100)
  grandTotal        Decimal           @default(0) @map("grand_total") @db.Decimal(15, 2)
  // Total yang harus dibayar = amount + total_interest + total_admin_fee
  installmentMonths Int               @map("installment_months")
  currentTerm       Int               @default(1) @map("current_term")
  monthlyAmount     Decimal           @map("monthly_amount") @db.Decimal(15, 2)
  kind              BillKind          @default(INSTALLMENT)
  paidTerms         Int               @default(0) @map("paid_terms")
  nextDueDate       DateTime          @map("next_due_date")
  status            InstallmentStatus @default(ACTIVE)
  startDate         DateTime          @map("start_date")
  description       String?
  balanceDeducted   Boolean           @default(false) @map("balance_deducted")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet         Wallet                   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  reminderEvents RecurringReminderEvent[]

  @@index([userId, status])
  @@index([walletId])
  @@map("installments")
}

// ─────────────────────────────────────────────
// RECURRING TRANSACTION TEMPLATE  (transaksi rutin)
// ─────────────────────────────────────────────
enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RecurringAmountMode {
  FIXED
  FLEXIBLE
}

model RecurringTransactionTemplate {
  id                 String              @id @default(cuid())
  userId             String              @map("user_id")
  walletId           String              @map("wallet_id")
  categoryId         String?             @map("category_id")
  name               String
  type               TransactionType
  amountMode         RecurringAmountMode @default(FIXED) @map("amount_mode")
  amount             Decimal?            @db.Decimal(15, 2)
  description        String?
  frequency          RecurrenceFrequency
  startDate          DateTime            @map("start_date")
  endDate            DateTime?           @map("end_date")
  isActive           Boolean             @default(true) @map("is_active")
  reminderEnabled    Boolean             @default(false) @map("reminder_enabled")
  reminderOffsetDays Int?                @map("reminder_offset_days")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  // Relations
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet         Wallet                   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category       Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reminderEvents RecurringReminderEvent[]

  @@index([userId, isActive])
  @@map("recurring_transaction_templates")
}

// Phase 4: one row per (template, occurrence, offset) that the reminder engine
// has already fired — the unique constraint is what makes re-running the
// engine for the same evaluation date a no-op instead of a duplicate.
// Phase 7: a row is sourced from either a recurring template OR an
// installment, never both — templateId/installmentId are each optional so
// the same table serves both without a parallel pipeline. The engine is the
// only writer and is responsible for setting exactly one of them.
model RecurringReminderEvent {
  id                     String    @id @default(cuid())
  templateId             String?   @map("template_id")
  installmentId          String?   @map("installment_id")
  userId                 String    @map("user_id")
  occurrenceDate         DateTime  @map("occurrence_date")
  offsetDays             Int       @map("offset_days")
  reminderDate           DateTime  @map("reminder_date")
  readAt                 DateTime? @map("read_at")
  // Phase 6: NULL = still waiting: non-null = a real transaction was created
  // from this reminder and it must never be processed again. Template-sourced
  // rows only — installment-sourced completion is derived, see notification
  // controller.
  completedAt            DateTime? @map("completed_at")
  generatedTransactionId String?   @unique @map("generated_transaction_id")
  createdAt              DateTime  @default(now()) @map("created_at")

  template             RecurringTransactionTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  installment          Installment?                  @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  generatedTransaction Transaction?                  @relation(fields: [generatedTransactionId], references: [id], onDelete: SetNull)

  @@unique([templateId, occurrenceDate, offsetDays])
  @@unique([installmentId, occurrenceDate, offsetDays])
  @@index([userId, reminderDate])
  @@map("recurring_reminder_events")
}

// ─────────────────────────────────────────────
// SAVING GOAL  (target tabungan)
// ─────────────────────────────────────────────
// Phase 8: a planning/tracking record only — it never creates a transaction,
// mutates a wallet balance, or affects net worth. Progress is stored directly
// on the row (currentAmount) with no contribution ledger; see
// financial-logic.skill.md before adding one.
enum SavingGoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model SavingGoal {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  name          String
  targetAmount  Decimal          @map("target_amount") @db.Decimal(15, 2)
  currentAmount Decimal          @default(0) @map("current_amount") @db.Decimal(15, 2)
  targetDate    DateTime?        @map("target_date")
  notes         String?
  status        SavingGoalStatus @default(ACTIVE)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("saving_goals")
}

// ─────────────────────────────────────────────
// BUDGET  (anggaran)
// ─────────────────────────────────────────────
// Phase A (PD-009, Approved): a recurring monthly spend-limit definition per
// user and expense Category — not a period-specific snapshot. Usage (spent,
// remaining, percentUsed, status) is always derived at read time from posted
// Transaction rows for the current reporting month; nothing is cached here.
// One persistent Budget per (userId, categoryId), archived or not — archiving
// does not free the category for a second Budget (PD-009 Decision L).
// Category expense-eligibility (categoryId must reference an EXPENSE-type
// Category owned by the same user) is enforced by the service layer, not the
// database, matching PD-009 Decision D.
model Budget {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  amount     Decimal  @db.Decimal(15, 2)
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId, isArchived])
  @@map("budgets")
}
