// ============================================================
// Pocket Mint — Personal Finance Tracker
// Prisma Schema for PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
  // Output must match the path imported by src/lib/prisma.ts
  // ('../generated/prisma/client', which resolves to this directory's shim).
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  // NOTE: no password column. Authentication is owned entirely by Supabase Auth;
  // this backend never stores, hashes, or verifies passwords. Local users are
  // linked to the verified Supabase identity via `id` (the JWT `sub` claim).
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  wallets                       Wallet[]
  categories                    Category[]
  transactions                  Transaction[]
  installments                  Installment[]
  recurringTransactionTemplates RecurringTransactionTemplate[]

  @@map("users")
}

// ─────────────────────────────────────────────
// WALLET  (rekening / e-wallet / paylater)
// ─────────────────────────────────────────────
enum WalletType {
  CASH
  BANK
  E_WALLET
  CREDIT_CARD
  PAYLATER
  LOAN
}

model Wallet {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  name           String
  type           WalletType   @default(CASH)
  balance        Decimal      @default(0) @db.Decimal(15, 2)
  creditLimit    Decimal      @default(0) @map("credit_limit") @db.Decimal(15, 2)
  initialBalance Decimal      @default(0) @map("initial_balance") @db.Decimal(15, 2)
  icon           String?
  color          String?
  interestRate   Decimal      @default(0) @map("interest_rate") @db.Decimal(5, 2)
  // Bunga flat per bulan dalam persen (contoh: 2.95 = 2.95%)
  // Default 0 untuk wallet tipe ASSET
  isArchived     Boolean      @default(false) @map("is_archived")
  adminFee       Decimal      @default(0) @map("admin_fee") @db.Decimal(15, 2)
  // Biaya admin default untuk wallet ini
  // FLAT    → nilai dalam Rupiah (contoh: 45000)
  // PERCENT → nilai dalam persen (contoh: 1.5 = 1.5%)
  adminFeeType   AdminFeeType @default(FLAT) @map("admin_fee_type")
  // Tipe kalkulasi biaya admin
  cutoffDay      Int?         @map("cutoff_day")
  paymentDueDay  Int?         @map("payment_due_day")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  user                          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions                  Transaction[]                  @relation("WalletTransactions")
  // Transfers whose destination is this wallet (Transaction.toWalletId).
  toTransactions                Transaction[]                  @relation("WalletToTransactions")
  installments                  Installment[]
  recurringTransactionTemplates RecurringTransactionTemplate[]

  @@index([userId])
  @@map("wallets")
}

// ─────────────────────────────────────────────
// CATEGORY  (kategori transaksi)
// ─────────────────────────────────────────────
enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  name      String
  type      CategoryType
  icon      String?
  color     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Relations
  user                          User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions                  Transaction[]
  recurringTransactionTemplates RecurringTransactionTemplate[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("categories")
}

// ─────────────────────────────────────────────
// TRANSACTION  (income / expense / transfer)
// ─────────────────────────────────────────────
enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  walletId      String          @map("wallet_id")
  // Destination wallet for TRANSFER rows. Persisting it makes a transfer
  // self-describing so update/delete can reverse BOTH sides from the stored
  // row (not from request data). Null for INCOME/EXPENSE and legacy transfers.
  toWalletId    String?         @map("to_wallet_id")
  categoryId    String?         @map("category_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  description   String?
  isInstallment Boolean         @default(false) @map("is_installment")
  installmentId String?         @map("installment_id")
  date          DateTime
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet      Wallet       @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)
  toWallet    Wallet?      @relation("WalletToTransactions", fields: [toWalletId], references: [id], onDelete: SetNull)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installment Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([walletId, date])
  @@index([toWalletId])
  @@index([categoryId])
  @@index([installmentId])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// INSTALLMENT  (cicilan)
// ─────────────────────────────────────────────
// ─────────────────────────────────────────────
// ADMIN FEE TYPE
// ─────────────────────────────────────────────
enum AdminFeeType {
  FLAT // nominal tetap dalam Rupiah
  PERCENT // persentase dari pokok transaksi
}

enum InstallmentStatus {
  ACTIVE
  SETTLED
  CANCELLED
}

enum BillKind {
  FULL
  INSTALLMENT
}

model Installment {
  id                String            @id @default(cuid())
  userId            String            @map("user_id")
  walletId          String            @map("wallet_id")
  totalAmount       Decimal           @map("total_amount") @db.Decimal(15, 2)
  interestRate      Decimal           @default(0) @map("interest_rate") @db.Decimal(5, 2)
  // Snapshot bunga saat transaksi cicilan dibuat
  totalInterest     Decimal           @default(0) @map("total_interest") @db.Decimal(15, 2)
  // Total bunga = amount × (interest_rate/100) × installmentMonths
  adminFee          Decimal           @default(0) @map("admin_fee") @db.Decimal(15, 2)
  // Snapshot nilai admin_fee saat transaksi dibuat
  adminFeeType      AdminFeeType      @default(FLAT) @map("admin_fee_type")
  // Snapshot tipe admin fee saat transaksi dibuat
  totalAdminFee     Decimal           @default(0) @map("total_admin_fee") @db.Decimal(15, 2)
  // Hasil kalkulasi aktual:
  // FLAT    → sama dengan admin_fee
  // PERCENT → amount × (admin_fee / 100)
  grandTotal        Decimal           @default(0) @map("grand_total") @db.Decimal(15, 2)
  // Total yang harus dibayar = amount + total_interest + total_admin_fee
  installmentMonths Int               @map("installment_months")
  currentTerm       Int               @default(1) @map("current_term")
  monthlyAmount     Decimal           @map("monthly_amount") @db.Decimal(15, 2)
  kind              BillKind          @default(INSTALLMENT)
  paidTerms         Int               @default(0) @map("paid_terms")
  nextDueDate       DateTime          @map("next_due_date")
  status            InstallmentStatus @default(ACTIVE)
  startDate         DateTime          @map("start_date")
  description       String?
  balanceDeducted   Boolean           @default(false) @map("balance_deducted")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, status])
  @@index([walletId])
  @@map("installments")
}

// ─────────────────────────────────────────────
// RECURRING TRANSACTION TEMPLATE  (transaksi rutin)
// ─────────────────────────────────────────────
enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model RecurringTransactionTemplate {
  id          String              @id @default(cuid())
  userId      String              @map("user_id")
  walletId    String              @map("wallet_id")
  categoryId  String?             @map("category_id")
  name        String
  type        TransactionType
  amount      Decimal             @db.Decimal(15, 2)
  description String?
  frequency   RecurrenceFrequency
  startDate   DateTime            @map("start_date")
  endDate     DateTime?           @map("end_date")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet   Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@map("recurring_transaction_templates")
}
